# Your city or "City, Province/State" (e.g. "Toronto, ON" or "Brooklyn, NY")
LOCATION=Toronto, ON

# How far to search (miles)
SEARCH_RADIUS_MILES=25

# Email settings
EMAIL_TO=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password

# Ticketmaster API key (free at https://developer.ticketmaster.com/)
TICKETMASTER_API_KEY=

# Azure SQL Database
SQL_SERVER=your-server.database.windows.net
SQL_DATABASE=WeeklyFunActivities
SQL_USER=your-sql-admin
SQL_PASSWORD=your-sql-password
SQL_DRIVER=ODBC Driver 17 for SQL Server
SQL_TRUSTED_CONNECTION=no
